//- views/public_user_profile.pug
//- Public user profile — cyberpunk aesthetic, full store-integrated cart.
//- Data from public_profile.js:
//-   user     { uid, handle, bio, photoURL, coverURL, joinDate, role, location }
//-   crates   [{ id, title, trackCount, coverImage, genres }]
//-   playerUrl      "/player/u/:handle" (authenticated deep-link)
//-   canonicalUrl   "https://eporia.com/u/:handle"

extends public_shell

block meta
  meta(property="og:description" content=user.bio || `${user.handle}'s profile on Eporia`)
  if user.coverURL || user.photoURL
    meta(property="og:image" content=user.coverURL || user.photoURL)


block content
  //- ── HERO ────────────────────────────────────────────────────────
  - var heroBg = user.coverURL ? `url('${user.coverURL}')` : ''
  .user-hero-pub(style=heroBg ? `background-image: ${heroBg}` : '')
    .user-hero-content
      img.user-hero-avatar(
        src=user.photoURL || "https://via.placeholder.com/100"
        alt=user.handle
      )
      .user-hero-text
        p.user-hero-eyebrow // USER PROFILE
        h2.user-hero-handle #{user.handle}

        .user-meta-row
          - var roleLabel = (user.role || 'MEMBER').toUpperCase()
          span.role-badge-pub(class=user.role === 'admin' ? 'admin' : '') #{roleLabel}
          if user.location
            span.dot •
            span
              i.fas.fa-map-marker-alt(style="opacity:0.5;margin-right:4px")
              | #{user.location}

        .user-hero-actions
          a.btn-hero-profile(href=playerUrl)
            i.fas.fa-user
            | View Full Profile
          button.btn-nav-ghost(
            onclick=`pubShareNative('${user.handle} on Eporia', 'Check out ${user.handle}\'s music crates on Eporia.', '${canonicalUrl}')`
          )
            i.fas.fa-share-alt
            |  Share

  //- ── SOCIAL SHARE ROW ────────────────────────────────────────────
  .pub-share-row(style="margin-top:20px")
    span.pub-share-label SHARE:
    button.btn-share-platform.twitter(
      onclick=`pubShareTwitter('Check out ${user.handle}\'s crates on Eporia:', '${canonicalUrl}')`
    )
      i.fab.fa-x-twitter
      |  X / Twitter
    button.btn-share-platform.facebook(
      onclick=`pubShareFacebook('${canonicalUrl}')`
    )
      i.fab.fa-facebook-f
      |  Facebook
    button.btn-share-platform.whatsapp(
      onclick=`pubShareWhatsApp('Check out ${user.handle}\'s crates on Eporia:', '${canonicalUrl}')`
    )
      i.fab.fa-whatsapp
      |  WhatsApp
    button.btn-share-platform.copy(
      onclick=`pubShare('${canonicalUrl}', this)`
    )
      i.fas.fa-link
      |  Copy Link

  .pub-divider

  //- ── MAIN CONTENT ────────────────────────────────────────────────
  .user-overview-grid

    //- ── LEFT: Bio sidebar ─────────────────────────────────────────
    aside
      .pub-bio-card
        p.pub-bio-card-title About
        if user.bio
          p.pub-bio-text #{user.bio}
        else
          p.pub-bio-text.empty No bio yet.
        .pub-bio-meta
          if user.location
            .pub-bio-meta-row
              i.fas.fa-map-marker-alt
              span #{user.location}
          if user.joinDate
            .pub-bio-meta-row
              i.fas.fa-calendar-alt
              - var joinStr = new Date(user.joinDate).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
              span Joined #{joinStr}
          .pub-bio-meta-row
            i.fas.fa-headphones
            a(href=playerUrl) Open in Eporia →

    //- ── RIGHT: Public Crates ──────────────────────────────────────
    section
      h3.pub-section-header(style="margin-bottom:6px")
        i.fas.fa-box-open(style="margin-right:8px;opacity:0.5")
        | Signature Stack
      p(style="font-family:'Share Tech Mono',monospace;font-size:0.72rem;color:var(--text-muted);margin-bottom:20px;letter-spacing:0.06em")
        | // PUBLIC CRATES — sign in to stream

      if crates && crates.length > 0
        .pub-crates-grid
          each crate in crates
            a.pub-crate-card(href="/members/signup")
              .pub-crate-cover-wrap
                img.pub-crate-cover(
                  src=crate.coverImage || "https://via.placeholder.com/170"
                  alt=crate.title
                )
                .pub-crate-overlay
                  .pub-crate-overlay-label
                    i.fas.fa-lock
                    | Open in Eporia
              .pub-crate-body
                p.pub-crate-title #{crate.title}
                .pub-crate-meta
                  i.fas.fa-music
                  span #{crate.trackCount} track#{crate.trackCount !== 1 ? 's' : ''}
                if crate.genres && crate.genres.length
                  .pub-crate-genre-row
                    each genre in crate.genres.slice(0, 3)
                      span.pub-crate-genre #{genre}

        p(style="text-align:center;margin-top:22px;font-family:'Rajdhani',sans-serif;font-size:0.85rem;color:var(--text-muted)")
          | Join Eporia free to stream these crates and follow #{user.handle}.&nbsp;
          a(href="/members/signup" style="color:var(--primary);font-weight:700") Create account →

      else
        .pub-empty
          i.fas.fa-box-open
          p No public crates yet.

block cta_strip
  .pub-cta-strip
    .pub-cta-left
      .pub-cta-icon
        i.fas.fa-user
      .pub-cta-text
        strong #{user.handle} is on Eporia
        span Follow their crates, discover their taste in music
    .pub-cta-actions
      a.btn-cta-open(href="/members/signup")
        i.fas.fa-user-plus
        | Join Free
      a.btn-cta-open(href=playerUrl style="border-color:var(--border-color);color:var(--text-secondary);box-shadow:none")
        i.fas.fa-arrow-right
        | Open Profile
