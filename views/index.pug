doctype html
html
  head
    title Eporia | The Artist's Platform
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    link(rel='stylesheet', href='/stylesheets/style.css')
    link(rel='stylesheet', href='/stylesheets/chatLandingPage.css')
    link(rel='stylesheet', href='/stylesheets/chatSection.css')
    link(rel='stylesheet', href='/stylesheets/artistBenefits.css')
    link(rel='stylesheet', href='/stylesheets/membershipPlans.css')
    link(rel='stylesheet', href='/stylesheets/humanSection.css')

  body.theme-electronic
    .cyber-grid
    .scanlines

    nav.landing-nav
      .logo
        .neon-sign
          span.neon-text(data-text="EPORIA") EPORIA
          .neon-flicker
      .nav-actions
        a.btn-nav-ghost(href="/store")
          span Store
        a.btn-nav-secondary(href="/members/signin")
          span Sign In
        a.btn-nav-secondary(href="/members/signup")
          span Signup
        a.btn-nav-ghost(href="#membership")
          span For Fans
        a.btn-nav-primary(href="/artist/onboarding")
          span Claim Artist Profile
          .btn-glow

    header.hero-section
      .hero-particles
      .hero-content
        h1.hero-title
          span.title-line Own Your Sound.
          span.title-line.highlight Get Paid Your Worth.
        p.hero-sub
          | The streaming era is broken. Eporia is the community-first platform where 
          span.stat-highlight 80% of membership revenue
          |  goes directly to the artists people actually listen to.
          br
          | No bots. No middlemen. Just you and your fans.

        .earnings-calculator
          .calculator-header
            h3
              i.fas.fa-calculator
              |  Earnings Simulator
            p.calculator-subtitle See what you could actually earn
          .calculator-body
            .input-section
              label.input-label
                i.fas.fa-users
                |  Number of Eporia Supporters
              .slider-container
                input.supporter-slider(type="range" min="1" max="100" value="10" id="supporterCount")
                .slider-value
                  span#supporterDisplay 10
                  |  supporters
            .comparison-results
              .result-item.spotify-result
                .result-header
                  img.platform-icon(src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%231DB954'%3E%3Cpath d='M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z'/%3E%3C/svg%3E" alt="Spotify")
                  span.platform-name Spotify
                .result-value
                  span.streams-needed
                    span#streamsNeeded 2,667
                    |  streams
                  span.equals-sign =
                  span.spotify-earning $
                    span#spotifyEarning 8.00
                .result-label To match your Eporia earnings
              .result-divider
                .divider-line
                span.vs-text VS
                .divider-line
              .result-item.eporia-result
                .result-header
                  .eporia-icon E
                  span.platform-name EPORIA
                .result-value.highlight
                  span.supporter-count
                    span#eporiaSupporter 1
                    |  <span id="supporterLabel">superfan</span>
                  span.equals-sign =
                  span.eporia-earning $
                    span#eporiaEarning 8.00
                .result-label Per month, directly to you
                .result-boost
                  i.fas.fa-arrow-up
                  |  <span id="streamsMultiplier">2,667</span>x fewer plays needed

        .cta-row
          a.btn-primary.btn-large(href="/artist/onboarding")
            span Start Earning
            .btn-glow
          a.btn-secondary.btn-large(href="#mission")
            span Learn More

        .hero-stats
          .stat-item
            .stat-number(data-target="80") 0
            .stat-label % to Artists
          .stat-divider
          .stat-item
            .stat-number(data-target="0") 0
            .stat-label Bot Streams
          .stat-divider
          .stat-item
            .stat-number(data-target="100") 0
            .stat-label % Human Verified

    section.local-vs-global
      .section-header
        h2
          span.section-number [01]
          |  Why Being #1 Locally Beats #100,000 Globally
        .header-line
      .comparison-callout
        .callout-content
          .callout-header
            i.fas.fa-lightbulb
            h3 Local Rankings = Real Money Signal
          .callout-stats
            .callout-stat
              .stat-platform Spotify #100,000
              .stat-streams 1,200 streams/month
              .stat-earning $3.60
              .stat-note Could be bots, playlists, or casual skips
            .callout-arrow
              i.fas.fa-arrow-right
            .callout-stat.winner
              .stat-platform Eporia #1 Local
              .stat-streams 150 paying supporters
              .stat-earning $1,200
              .stat-note Real fans spending real money monthly
          p.callout-message
            | When you're #1 in San Diego with 150 supporters, that's 150 people 
            span.highlight-accent paying $10/month
            |  just to listen to you. This matters to venues, promoters, and labels—it's proof your fans are genuinely invested. Plus, local listeners 
            strong see you first
            |  when they open Eporia. Your city, your advantage.
      .local-benefits
        .benefit-item
          .benefit-icon
            i.fas.fa-eye
          h4 Instant Visibility
          p When listeners open Eporia, they see their city's artists first. No algorithm to beat—just be good and be local.
        .benefit-item
          .benefit-icon
            i.fas.fa-ticket-alt
          h4 Venue Credibility
          p "150 paying monthly supporters" tells venues and promoters more than "10,000 Spotify streams." It's proof people will actually buy tickets.
        .benefit-item
          .benefit-icon
            i.fas.fa-dollar-sign
          h4 Paying Fans, Not Passive Streams
          p Your ranking shows committed listeners who financially support you every month—the kind of fans who come to shows and buy merch.

    section.mission-section#mission
      .section-header
        h2
          span.section-number [02]
          |  Why We Built This
        .header-line
      .mission-grid
        .feature-card(data-index="01")
          .card-corner.corner-tl
          .card-corner.corner-tr
          .card-corner.corner-bl
          .card-corner.corner-br
          .card-icon
            i.fas.fa-money-bill-wave
          h3 80% Direct Allocation
          p
            | On other platforms, you need 
            span 3,000 streams
            |  to buy a coffee. On Eporia, 
            span.highlight-accent 1 subscriber can net you more than 3,000 Spotify streams.
            |  When a fan pays $10, $8 goes to the artists they listened to that month. Period.
          .card-data
            .data-point
              span.data-label Industry Avg
              span.data-value.bad $0.003
            .data-point
              span.data-label Eporia Model
              span.data-value.good $8.00+
        .feature-card(data-index="02")
          .card-corner.corner-tl
          .card-corner.corner-tr
          .card-corner.corner-bl
          .card-corner.corner-br
          .card-icon.accent
            i.fas.fa-users
          h3 Credit Where It's Due
          p
            | Music isn't a solo act. Our metadata engine ensures producers, engineers, and songwriters get credited 
            | and paid. Build your team, split the revenue, and grow together.
          .card-tech
            span.tech-badge Smart Contracts
            span.tech-badge Auto-Split
            span.tech-badge Full Transparency
        .feature-card(data-index="03")
          .card-corner.corner-tl
          .card-corner.corner-tr
          .card-corner.corner-bl
          .card-corner.corner-br
          .card-icon
            i.fas.fa-shield-alt
          h3 Manually Vetted & Bot-Free
          p
            | We manually review every submission. No algorithm gaming, no click-farms, and no AI-generated spam cluttering the feed. 
            | Just real music from real humans.
          .verification-badge
            i.fas.fa-check-circle
            span 100% Human Verified
        .feature-card(data-index="04")
          .card-corner.corner-tl
          .card-corner.corner-tr
          .card-corner.corner-bl
          .card-corner.corner-br
          .card-icon.accent
            i.fas.fa-map-marked-alt
          h3 Dominate Your City
          p
            | Global algorithms bury local talent. Our 
            strong City Dashboards
            |  prioritize local artists to local listeners. 
            | Become a hometown hero before taking on the world.
          .city-viz
            .city-pulse
            span.city-label Local Discovery Engine
      .problem-section
        .problem-header
          span.problem-label THE PROBLEM
          h3 The Streaming Industry is Broken
        .problem-stats
          .problem-stat
            .problem-number 3,000
            .problem-text
              | Spotify streams = 
              span.highlight $9
          .problem-arrow →
          .problem-stat
            .problem-number 1
            .problem-text
              | Eporia subscriber = 
              span.highlight-accent $8
        p.problem-description
          | Major platforms pay fractions of a cent per stream. Artists need millions of plays to make minimum wage. 
          | Meanwhile, streaming services keep 
          span.highlight 70-80% of revenue
          | . We're flipping that model.

    section.commerce-section
      .section-header
        h2
          span.section-number [03]
          |  100% Artist Payout. Every Single Sale.
        .header-line
      .commerce-intro
        p.commerce-lead
          | Independent creators lose thousands every year to platform fees on merchandise.
          | We built our store to compete directly with Bandcamp — by 
          span.highlight-accent restructuring who pays the fee.
          |  The artist always keeps 100% of their listed price. Always.
      .commerce-pillars
        .pillar-card
          .pillar-icon
            i.fas.fa-calculator
          .pillar-number 01
          h4 Reverse Calculation
          p We don't add a percentage on top and hope. We work backwards from your payout target, guaranteeing your $50 shirt pays you $50 — after every processor fee.
          .pillar-formula
            span.formula-label Formula
            code.formula-code Total = (Payout + Fee + $0.30) / (1 − 0.029)
        .pillar-card
          .pillar-icon.accent
            i.fas.fa-percent
          .pillar-number 02
          h4 Tax-Inclusive Pricing
          p For your first $600 in sales, we bake a tax buffer into the service fee. The buyer sees a lower final price than they would on any competitor — reducing cart abandonment.
          .pillar-badge
            i.fas.fa-tag
            span Covers first 5% of sales tax
        .pillar-card
          .pillar-icon
            i.fas.fa-handshake
          .pillar-number 03
          h4 Transparent Fan Fee
          p Processing fees for established shops are shown as a "Supporter Fee" paid by the fan — not deducted from you. Fans of independent artists consistently pay it without hesitation.
          .pillar-badge.accent
            i.fas.fa-heart
            span Fans pay it. You keep everything.
      .commerce-compare
        .compare-header
          span.compare-label LIVE MATH · $50 HOODIE EXAMPLE
          h3 How Our Model Stacks Up
        .compare-table
          .compare-row.compare-head-row
            span Phase
            span Fan Pays
            span Artist Gets
          .compare-row.tier-row
            .tier-label(data-label="Phase")
              span.tier-badge T1
              span Under $600 / month
            span.fan-price(data-label="Fan Pays")
              | $54.50
              small  ($50 + $4.50 fee)
            span.artist-payout.winner(data-label="Artist Gets") $50.00
          .compare-row.tier-row.tier-2
            .tier-label(data-label="Phase")
              span.tier-badge.accent T2
              span Over $600 / month
            span.fan-price(data-label="Fan Pays")
              | $56.35
              small  ($50 + $4.50 + $1.85)
            span.artist-payout.winner(data-label="Artist Gets") $50.00
      .commerce-vs
        .compare-header
          span.compare-label SIDE BY SIDE
          h3 Eporia vs. Bandcamp
        .vs-table
          .vs-head
            span Platform
            span Listed Price
            span Added at Checkout
            span Fan Pays
            span.col-highlight Artist Gets
          .vs-row.vs-competitor
            .vs-platform(data-label="Platform")
              span.platform-dot.bad
              span Bandcamp
            span(data-label="Listed Price") $50.00
            span(data-label="Added at Checkout") $4.00 tax
            span(data-label="Fan Pays") $54.00
            span.artist-take.bad(data-label="Artist Gets") $41.25
          .vs-row.vs-eporia
            .vs-platform(data-label="Platform")
              span.platform-dot.good
              span Eporia (Tier 1)
            span(data-label="Listed Price") $50.00
            span(data-label="Added at Checkout") $4.50 fee
            span(data-label="Fan Pays") $54.50
            span.artist-take.winner(data-label="Artist Gets") $50.00
          .vs-row.vs-eporia
            .vs-platform(data-label="Platform")
              span.platform-dot.good
              span Eporia (Tier 2)
            span(data-label="Listed Price") $50.00
            span(data-label="Added at Checkout") $6.35 fees
            span(data-label="Fan Pays") $56.35
            span.artist-take.winner(data-label="Artist Gets") $50.00
        .vs-verdict
          .verdict-icon
            i.fas.fa-trophy
          .verdict-text
            strong Even in our "most expensive" tier
            | , your artist makes 
            span.highlight-accent $8.75 more per shirt
            |  than they would on Bandcamp.

    section.human-section
      .section-header
        h2
          span.section-number [04]
          |  Every Artist Here Is Real.
        .header-line

      //- ── Cinematic image manifesto strip ──
      .human-visual-manifesto
        .human-img-strip
          .human-img-frame.frame-keyboard
            img(src="/images/artists/keyboard-artist.jpg" alt="Artist performing live under neon lights")
            .img-cyber-overlay
            .img-scanlines
            .img-corner.tl
            .img-corner.tr
            .img-corner.bl
            .img-corner.br
            .img-label
              span.img-tag // LIVE
              span.img-tag-divider ·
              span.img-tag HUMAN
          .human-img-frame.frame-street.frame-featured
            img(src="/images/artists/street-musicians.jpg" alt="Street musicians performing together")
            .img-cyber-overlay.overlay-warm
            .img-scanlines
            .img-corner.tl
            .img-corner.tr
            .img-corner.bl
            .img-corner.br
            .img-label
              span.img-tag // CRAFT
              span.img-tag-divider ·
              span.img-tag CULTURE
            .img-caption-badge
              i.fas.fa-check-circle
              span Human Verified
          .human-img-frame.frame-crowd
            img(src="/images/artists/concert-crowd.jpg" alt="Concert crowd connecting with music")
            .img-cyber-overlay.overlay-fire
            .img-scanlines
            .img-corner.tl
            .img-corner.tr
            .img-corner.bl
            .img-corner.br
            .img-label
              span.img-tag // REAL
              span.img-tag-divider ·
              span.img-tag CONNECTION
        .human-manifesto-bar
          span.manifesto-line NOT GENERATED
          span.manifesto-dot ◆
          span.manifesto-line NOT SIMULATED
          span.manifesto-dot ◆
          span.manifesto-line NOT AUTOMATED
          span.manifesto-dot ◆
          span.manifesto-line NOT NEGOTIABLE

      .human-intro
        p.human-lead
          | The reason people pay for music isn't because it sounds good.
          br
          | It's because 
          span.highlight-accent someone sat down, learned something hard, failed at it, tried again,
          |  and eventually made something that couldn't have existed without them.
          br
          br
          | We're not interested in hosting the output of a machine that skipped all of that.
      .ai-policy-block
        .policy-icon
          i.fas.fa-ban
        .policy-text
          h3 No AI-Generated Music. Full Stop.
          p
            | Eporia does not allow AI-generated music, AI-assisted compositions presented as original works,
            | or artist profiles operated by bots or on behalf of non-humans. This isn't a checkbox 
            | in our terms of service — it's enforced through the way we onboard every artist on this platform.
      .human-pillars
        .human-card
          .human-card-number 01
          .human-card-icon
            i.fas.fa-user-check
          h4 Manual Review. Every Time.
          p
            | There is no "sign up and start uploading." Every artist application is reviewed by a real person 
            | on our team before a profile is approved. We look at your music, your history, your craft. 
            | This takes longer. We think it's worth it.
        .human-card
          .human-card-number 02
          .human-card-icon
            i.fas.fa-envelope-open-text
          h4 We Invite Artists We Believe In.
          p
            | Beyond open applications, we actively reach out to artists we discover and personally invite them to 
            | the platform. Not with an algorithm — with a conversation. If we're asking you to join, 
            | it's because we listened.
        .human-card
          .human-card-number 03
          .human-card-icon
            i.fas.fa-file-contract
          h4 You Own What You Made.
          p
            | Every artist on Eporia must own the rights to what they upload. We verify this during onboarding.
            | Your music stays yours. You can leave the platform at any time and take everything with you.
      .human-philosophy
        .philosophy-quote
          .quote-mark "
          blockquote
            | We are a small, boutique software company. We have no interest in infinite scroll, 
            | infinite artists, or infinite content. We'd rather have 500 artists who are genuinely 
            | exceptional than 500,000 accounts no one asked for.
          .quote-mark.closing "
        .philosophy-attribution
          span — Eporia
      .human-fan-row
        .fan-side
          .fan-label FOR FANS
          h4 You know every song came from a human being.
          p
            | When you support an artist on Eporia, you're supporting a real person — someone who spent 
            | real time making something real. You'll never accidentally fund a click-farm, 
            | a content mill, or a script. Every payout goes to a human with a name.
        .fan-divider
        .fan-side
          .fan-label FOR ARTISTS
          h4 You're not competing with bots.
          p
            | On major platforms, AI-generated tracks flood the catalog and dilute algorithmic reach 
            | for human artists. On Eporia, the playing field only contains people who did the work. 
            | Your craft is not in a race against automation here.

    //- ================================================================
    //- [05] BUILT FOR ARTISTS. RUN WITH ARTISTS.
    //- ================================================================
    section.benefits-section#artist-benefits
      .section-header
        h2
          span.section-number [05]
          |  Built For Artists. Run With Artists.
        .header-line

      .benefits-intro
        p.benefits-lead
          | Most platforms take from artists. Eporia is structured so that our 
          span.highlight 20% cut covers every cost we have
          | — legal, infrastructure, support — so we 
          span.highlight-accent never need to nickel-and-dime you
          |  anywhere else. Here's what that looks like in practice.

      .benefits-top-grid

        .benefit-card
          .benefit-card-icon
            i.fas.fa-cloud-upload-alt
          h4 Unlimited Uploads + Mastering
          p
            | Upload as many tracks as you want — no storage caps, no per-song fees. 
            | Need a professional master? We offer optional 
            strong Algorithmic mastering that you can apply to any track,
            |  directly inside your dashboard, so your music sounds release-ready without hiring a third party.
          .benefit-price-badge
            i.fas.fa-infinity
            |  Unlimited Songs
          span.benefit-price-label Included with your artist profile

        .benefit-card.accent-card
          .benefit-card-icon
            i.fas.fa-globe
          h4 $10 Lifetime Distribution
          p
            | Get your music on Spotify, Apple Music, Amazon, and every major platform for a 
            strong one-time $10 fee
            | . No annual renewal. No "legacy fee" that kicks in when your music starts earning. 
            | Your catalog stays distributed for life.
          .benefit-price-badge.magenta
            i.fas.fa-dollar-sign
            |  $10 Lifetime
          span.benefit-price-label No renewals. No legacy fees. Ever.

        .benefit-card
          .benefit-card-icon
            i.fas.fa-music
          h4 Cover Songs for $1
          p
            | Want to record a cover? We handle the mechanical licensing, 
            | track down the rights holders, and manage royalty payouts on your behalf — 
            | all for 
            strong $1 per cover song
            | . No lawyers. No paperwork. No surprises.
          .benefit-price-badge
            i.fas.fa-gavel
            |  $1 Per Cover
          span.benefit-price-label Licensing + royalty routing included

      .coop-banner

        .coop-card
          .coop-card-icon
            i.fas.fa-people-arrows
          .coop-card-body
            h4 You're a Partner, Not a Product
            p
              | Eporia is a 
              strong cooperative
              | . Artists on the platform have a direct line to us — vote on upcoming features, 
              | flag what isn't working, and shape the roadmap. We hold regular feedback sessions and 
              | treat artist input as the most important signal we have. If you want a feature, tell us.

        .coop-card.noads
          .coop-card-icon
            i.fas.fa-ban
          .coop-card-body
            h4 No Ads. Not Now. Not Ever.
            p
              | We will never sell ad space on Eporia. No banner ads, no sponsored placements, 
              | no promoted tracks that push you out of your listener's feed. Our revenue model is 
              strong memberships only
              | — which means our incentives stay perfectly aligned with yours.

      .revenue-flow-block
        .flow-header
          .flow-header-icon
            i.fas.fa-chart-pie
          div
            h3 Where Every $12.99 Membership Goes
            span &nbsp;·&nbsp; BASED ON A $12.99/MONTH MEMBERSHIP FEE
        .flow-bar-row
          span.flow-bar-label Artists
          .flow-bar-track
            .flow-bar-fill.primary(data-width="80%")
          span.flow-bar-pct 80%
        .flow-bar-row
          span.flow-bar-label Eporia
          .flow-bar-track
            .flow-bar-fill.muted(data-width="20%")
          span.flow-bar-pct.muted 20%
        p.flow-note
          | The 20% Eporia keeps covers 
          strong all
          |  platform costs — server infrastructure, manual artist review, legal & licensing, 
          | payment processing, and ongoing development. No hidden fees. No surprise deductions. 
          | The 80% that leaves our hands goes to artists, guaranteed.

      .payment-models-block
        .payment-models-header
          h3 Two Ways Fans Can Support You
          p CHOOSE THE MODEL THAT FITS YOUR LISTENERS · BOTH GUARANTEE 80% TO ARTISTS
        .payment-tabs
          button.payment-tab.active(type="button" data-panel="panel-hybrid") Hybrid Model
          button.payment-tab(type="button" data-panel="panel-manual") Manual Allocation
        #panel-hybrid.payment-panel.active
          .panel-desc
            h4 Hybrid Model — Proof of Fandom
            p
              strong 60% of a fan's membership
              |  flows into our 
              strong Proof-of-Fandom pool
              | . At month's end, we calculate each artist's share based on 
              em real engagement metrics
              |  — not passive play counts. Genuine listens, saves, shares, and active engagement determine your cut.
            p
              | The remaining 
              strong 20%
              |  is deposited as credits into the fan's wallet. They can then 
              strong manually tip or allocate
              |  those credits to any artist they choose — putting the final say in the fan's hands.
            .panel-note
              | — Fan metrics are weighted to prevent gaming. A single dedicated listener who actively engages counts far more than someone who leaves your track on repeat overnight.
          .panel-visual
            .panel-pie-row
              .pie-swatch.primary
              span.pie-row-label Proof-of-Fandom pool
              span.pie-row-pct 60%
            .panel-pie-row
              .pie-swatch.dim
              span.pie-row-label Fan wallet credits (manual)
              span.pie-row-pct 20%
            .panel-pie-row
              .pie-swatch.muted
              span.pie-row-label Eporia platform
              span.pie-row-pct.muted 20%

        #panel-manual.payment-panel
          .panel-desc
            h4 Manual Allocation — Full Fan Control
            p
              strong 80% of the fan's membership
              |  goes directly into their Eporia wallet as credits. They then 
              strong decide exactly where that money goes
              |  — which artists, how much, when.
            p
              | Fans who feel strongly about specific artists gravitate toward this model. It rewards the artists 
              | with the most personally invested fanbase, and gives those fans a satisfying sense of agency over who they support.
            .panel-note
              | — The full 80% is always guaranteed to artists regardless of which model the fan chooses. Eporia only ever takes its 20%.
          .panel-visual
            .panel-pie-row
              .pie-swatch.primary
