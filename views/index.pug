    script(src='/javascripts/chat.js')
    script.
      // ── Membership billing toggle ──────────────────────────
      (function() {
        const prices = {
          discovery: { month: '$7.99', year: '$6.49', yearNote: '$77.90 billed yearly' },
          supporter: { month: '$12.99', year: '$10.49', yearNote: '$125.90 billed yearly' },
          champion:  { month: '$24.99', year: '$20.24', yearNote: '$242.90 billed yearly' }
        };
        const toggle = document.getElementById('billingToggle');
        if (!toggle) return;
        function updatePrices() {
          const isYear = toggle.checked;
          document.getElementById('labelMonthly').classList.toggle('active', !isYear);
          document.getElementById('labelYearly').classList.toggle('active', isYear);
          Object.keys(prices).forEach(key => {
            const p = prices[key];
            const priceEl = document.getElementById('price' + key.charAt(0).toUpperCase() + key.slice(1));
            const yearEl  = document.getElementById('year'  + key.charAt(0).toUpperCase() + key.slice(1));
            if (priceEl) priceEl.textContent = isYear ? p.year : p.month;
            if (yearEl)  yearEl.textContent  = isYear ? p.yearNote : '';
          });
        }
        toggle.addEventListener('change', updatePrices);
      })();
