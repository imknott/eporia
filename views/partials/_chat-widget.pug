//- ================================================================
//- EPORIA STICKY CHAT WIDGET — HTML PARTIAL
//- views/partials/_chat-widget.pug
//-
//- Include this at the bottom of any page body, before scripts:
//-   include partials/_chat-widget.pug
//-
//- Also add to the page's <head>:
//-   link(rel='stylesheet' href='/stylesheets/chat-widget.css')
//-
//- And load the script at the bottom of <body>:
//-   script(src='/javascripts/chat.js')
//- ================================================================

//- Desktop-only sticky widget (hidden < 1024px via CSS)
#epChatWidget.ep-collapsed

  //- ── Expanded terminal panel ──────────────────────────────────
  #epChatPanel

    //- Title bar — click anywhere to collapse
    .ep-titlebar(onclick="epToggle()")
      .ep-titlebar-left
        .ep-dots
          .ep-dot.ep-dot-r
          .ep-dot.ep-dot-a
          .ep-dot.ep-dot-g
        span.ep-title-text EPORIA_UNDERGROUND.SH
      .ep-titlebar-right
        .ep-status-dot
        button.ep-collapse-btn(
          type="button"
          onclick="event.stopPropagation();epToggle()"
          aria-label="Minimize chat"
        )
          i.fas.fa-minus

    //- Sys info strip
    .ep-sysbar
      span.ep-sysbar-item
        | SYS://&nbsp;
        span.ep-sysbar-val CONNECTED
      span.ep-sysbar-item
        | NET://&nbsp;
        span.ep-sysbar-val ENCRYPTED
      span.ep-sysbar-item
        | ARTISTS://&nbsp;
        span.ep-sysbar-val 2,847

    //- Message feed
    .ep-messages#epMsgs

    //- FAQ quick-select pills (horizontal scroll, populated by JS)
    .ep-faq-row#epFaqRow

    //- Input row
    .ep-input-area
      span.ep-prompt >&nbsp;
      textarea.ep-input#epInput(
        rows="1"
        placeholder="Ask me anything..."
        autocomplete="off"
        spellcheck="false"
      )
      button.ep-send#epSendBtn(type="button" aria-label="Send message")
        i.fas.fa-chevron-right

  //- ── Minimized pill ───────────────────────────────────────────
  //- Shown only when widget is collapsed
  #epChatPill(onclick="epToggle()")
    .ep-pill-dot
    span.ep-pill-label EPORIA
    span.ep-pill-preview#epPillPreview Ask me anything...
    span.ep-pill-arrow ↑
