//- ==========================================
//- PAYMENTS & FINANCIALS VIEW
//- Partial: views/artist/partials/_view-payments.pug
//- Included in artist_studio.pug
//- ==========================================
section#view-payments.view-section

  .payments-header
    div
      h2.payments-title Payments & Financials
      p.payments-subtitle Your earnings, payouts, and Stripe account setup
    .payout-badge#payoutStatusBadge
      i.fas.fa-circle-notch.fa-spin
      span Checking status...

  //- ── Earnings summary cards ──────────────────────────────────
  .earnings-grid

    .earnings-card
      .earnings-card__icon.green
        i.fas.fa-dollar-sign
      .earnings-card__body
        .earnings-card__value#earningsThisMonth $0.00
        .earnings-card__label This Month
        .earnings-card__sub(id="earningsMonthRange") —

    .earnings-card
      .earnings-card__icon.orange
        i.fas.fa-clock
      .earnings-card__body
        .earnings-card__value#earningsPending $0.00
        .earnings-card__label Pending Payout
        .earnings-card__sub Next payout: <span id="nextPayoutDate">—</span>

    .earnings-card
      .earnings-card__icon.blue
        i.fas.fa-chart-bar
      .earnings-card__body
        .earnings-card__value#earningsLifetime $0.00
        .earnings-card__label Lifetime Earned
        .earnings-card__sub All time on Eporia

  //- ── Payout progress bar ────────────────────────────────────
  .payout-threshold-card
    .payout-threshold-card__header
      span.payout-threshold-card__title
        i.fas.fa-calendar-alt
        |  Monthly Payout Threshold
      span.payout-threshold-card__note Paid on the 15th of each month
    .payout-threshold-bar-wrap
      .payout-threshold-bar
        .payout-threshold-bar__fill#thresholdFill(style="width:0%")
        .payout-threshold-bar__marker(title="$50 minimum")
      .payout-threshold-labels
        span#thresholdAmount $0.00 earned
        span.payout-threshold-labels__min $50 minimum

    .payout-threshold-status#thresholdStatus
      i.fas.fa-info-circle
      |  Earn $50 this month to qualify for the 15th payout.

  //- ── Lifetime Distribution ──────────────────────────────────
  .distro-card#distroCard

    //- State A: not yet purchased — shown by default, hidden by JS once paid
    .distro-card__cta#distroCta
      .distro-card__icon
        i.fas.fa-globe-americas
      .distro-card__body
        h3 Lifetime Music Distribution
        p Distribute your music to Spotify, Apple Music, Tidal and 150+ platforms. One payment, yours forever — keep 100% of your royalties.
        .distro-card__price
          span.distro-price $10
          span.distro-price-label  one-time · no annual fees · 100% royalties
      button.btn-primary#distroUpgradeBtn(onclick="startDistroPayment()")
        i.fas.fa-rocket
        |  Get Lifetime Distribution

    //- State B: already active — hidden by default, shown by JS
    .distro-card__active#distroActive(style="display:none")
      .distro-active__icon
        i.fas.fa-check-circle
      .distro-active__body
        h3 Lifetime Distribution Active
        p You have lifetime access to music distribution. Keep 100% of your royalties forever.
        p.distro-active__since#distroActiveSince &nbsp;

  //- ── Stripe Connect embedded area ───────────────────────────
  .stripe-connect-wrap

    //- Onboarding banner — shown when stripeOnboarded === false
    .stripe-onboarding-banner#stripeOnboardingBanner(style="display:none")
      .stripe-onboarding-banner__icon
        i.fas.fa-university
      .stripe-onboarding-banner__body
        h3 Set Up Your Payout Account
        p Connect your bank so Eporia can send your earnings directly to you. Takes about 2 minutes.
      button.btn-primary#startOnboardingBtn(onclick="startStripeOnboarding()")
        i.fas.fa-external-link-alt
        |  Set Up Payouts

    //- Stripe embedded components mount here once onboarding is complete
    #stripeComponentsWrap(style="display:none")
      .stripe-section-label
        i.fab.fa-stripe
        |  Transaction History &amp; Account
      //- Stripe Connect JS mounts <stripe-connect-payments> here
      #stripePaymentsComponent
      //- Stripe Connect notification banner (shows action items)
      #stripeNotificationBanner

    //- Loading skeleton shown while we fetch the session
    .stripe-loading#stripeLoading(style="display:none")
      .stripe-loading__spinner
        i.fas.fa-circle-notch.fa-spin
      span Loading your payment dashboard...

    //- Shown if artist has no Stripe account yet (very first approval)
    .stripe-no-account#stripeNoAccount(style="display:none")
      i.fas.fa-exclamation-triangle
      span Your payout account hasn't been created yet. Contact support if this persists.

  //- ── HITS Act Production Expense Tracker ────────────────────
  .hits-section
    .hits-header
      .hits-header-left
        h3
          i.fas.fa-file-invoice-dollar(style="color:var(--primary); margin-right:10px")
          | HITS Act — Production Expense Tracker
        p.hits-subtitle
          | Track up to&nbsp;
          strong $150,000
          | &nbsp;in deductible production costs per year. Export a CPA-ready CSV at tax time.
      .hits-header-right
        select#hitsYearSelect(onchange="window.hitsTracker?.loadExpenses()")
          - var y = new Date().getFullYear()
          option(value=`${y}`) #{y}
          option(value=`${y-1}`) #{y-1}
          option(value=`${y-2}`) #{y-2}
        button.btn-secondary#hitsExportBtn(onclick="window.hitsTracker?.exportCSV()")
          i.fas.fa-download
          span Export CSV

    //- Deduction progress bar
    .hits-progress-wrap
      .hits-progress-bar
        .hits-progress-fill#hitsProgressFill(style="width:0%")
      .hits-progress-labels
        span#hitsSpentLabel $0.00 logged
        span.hits-limit $150,000 limit

    //- Add expense form
    .hits-add-form#hitsAddForm
      h4 Add Expense
      .hits-form-row
        input.hits-input#hitsDate(type="date" placeholder="Date")
        select.hits-input#hitsCategory
          option(value="" disabled selected) Category
          - var cats = ['Studio Recording','Session Musicians','Music Video Production','Equipment & Gear','Software & Plugins','Sample Licensing','Cover Art & Design','Music Distribution','Marketing & Promotion','Legal & Copyright','Travel & Accommodation','Other Production Cost']
          each cat in cats
            option(value=cat)= cat
        input.hits-input#hitsAmount(type="number" min="0.01" step="0.01" placeholder="Amount $")
      .hits-form-row
        input.hits-input(style="flex:3" id="hitsDescription" type="text" placeholder="Description (e.g. Studio session at Red Bull Studios)")
        input.hits-input(style="flex:2" id="hitsNotes" type="text" placeholder="Notes (optional)")
        button.btn-primary#hitsAddBtn(onclick="window.hitsTracker?.addExpense()")
          i.fas.fa-plus
          span Add

    //- Expense list
    .hits-list-wrap
      table.hits-table
        thead
          tr
            th Date
            th Category
            th Description
            th Notes
            th(style="text-align:right") Amount
            th(style="text-align:center") Receipt
            th
        tbody#hitsExpenseList
          tr
            td(colspan="7" style="text-align:center; padding:30px; color:var(--text-secondary)")
              i.fas.fa-circle-notch.fa-spin
              |  Loading expenses...
