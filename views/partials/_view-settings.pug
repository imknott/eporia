#view-settings.view-section

  header.top-header
    div
      h1 Account Settings
      p.top-header-sub Manage your login credentials, location, and account security.

  .settings-container

    //- ── Email Address ──────────────────────────────────────────
    .settings-section
      h3
        i.fas.fa-envelope(style="color:var(--primary);margin-right:10px")
        | Email Address
      p Update the email address used to sign in to your artist account.
      form#emailUpdateForm(style="margin-top:20px;max-width:460px")
        .input-group
          label New Email Address
          input.studio-input(type="email" id="newEmail" placeholder="your@email.com" required)
        .input-group(style="margin-top:14px")
          label Confirm with Password
          input.studio-input(type="password" id="emailConfirmPassword" placeholder="Your current password" required)
        button.btn-primary(type="submit" id="btnUpdateEmail" style="margin-top:18px;display:flex;align-items:center;gap:8px;")
          i.fas.fa-envelope
          | Update Email

    //- ── Location ───────────────────────────────────────────────
    .settings-section(style="margin-top:32px")
      h3
        i.fas.fa-map-marker-alt(style="color:var(--primary);margin-right:10px")
        | Location
      p Your city or region shown on your public profile and in the app.
      form#locationUpdateForm(style="margin-top:20px;max-width:460px")
        .input-group
          label Location
          input.studio-input(type="text" id="artistLocation" placeholder="e.g. Los Angeles, CA" maxlength="100")
        button.btn-primary(type="submit" id="btnUpdateLocation" style="margin-top:18px;display:flex;align-items:center;gap:8px;")
          i.fas.fa-save
          | Save Location

    //- ── Password ───────────────────────────────────────────────
    .settings-section(style="margin-top:32px")
      h3
        i.fas.fa-lock(style="color:var(--primary);margin-right:10px")
        | Password
      p Update your password. You will need to log in again after changing it.
      form#passwordUpdateForm(style="margin-top:20px;max-width:460px")
        .input-group
          label New Password
          input.studio-input(type="password" id="newPassword" placeholder="Minimum 6 characters" required minlength="6")
        .input-group(style="margin-top:14px")
          label Confirm Password
          input.studio-input(type="password" id="confirmPassword" placeholder="Minimum 6 characters" required minlength="6")
        button.btn-primary(type="submit" id="btnUpdatePassword" style="margin-top:18px;display:flex;align-items:center;gap:8px;")
          i.fas.fa-lock
          | Update Password

    //- ── Danger Zone ────────────────────────────────────────────
    .settings-section.danger-zone(style="margin-top:40px")
      h3(style="color:var(--danger)")
        i.fas.fa-exclamation-triangle(style="margin-right:10px")
        | Danger Zone
      p Permanently delete your artist account and all associated data. This cannot be undone.
      button.btn-danger(onclick="confirmAccountDeletion()" style="margin-top:16px;display:flex;align-items:center;gap:8px;")
        i.fas.fa-trash-alt
        | Delete Artist Account

