#view-settings.view-section
  header.top-header
    h1 Settings
    button.btn-secondary(onclick="switchView('overview')") 
      i.fas.fa-arrow-left
      span Back
  
  .settings-container
    .settings-section(style="margin-bottom: 40px; padding-bottom: 30px; border-bottom: 1px solid rgba(255,255,255,0.1);")
      h3 Profile Customization
      p Update your public artist image, banner, and bio.

      form#artistProfileForm(style="margin-top: 20px; max-width: 500px;")
        .input-group
          label Profile Image (Avatar)
          .image-upload-wrapper(style="display: flex; align-items: center; gap: 15px; margin-top: 10px;")
            img#avatarSettingsPreview(src="https://via.placeholder.com/100" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid var(--border-color);")
            input.studio-input(type="file" id="avatarInput" accept="image/*" style="flex: 1;")

        .input-group(style="margin-top: 20px;")
          label Banner Image (Hero Background)
          .image-upload-wrapper(style="margin-top: 10px;")
            img#bannerSettingsPreview(src="https://via.placeholder.com/400x150" style="width: 100%; height: 120px; border-radius: 8px; object-fit: cover; border: 2px solid var(--border-color); margin-bottom: 10px;")
            input.studio-input(type="file" id="bannerInput" accept="image/*")

        .input-group(style="margin-top: 20px;")
          label Artist Bio
          textarea.studio-input#settingsBio(rows="4" placeholder="Tell your fans about your journey...")

        button.btn-primary(type="submit" id="btnUpdateProfile" style="margin-top: 20px; width: 100%;")
          i.fas.fa-save(style="margin-right: 8px;")
          | Save Profile Changes

    .settings-section
      h3 Security & Password
      p Update your temporary password to secure your account.
      
      form#passwordUpdateForm(style="margin-top: 20px; max-width: 400px;")
        .input-group
          label New Password
          input.studio-input(type="password" id="newPassword" placeholder="Minimum 6 characters" required minlength="6")
        .input-group(style="margin-top: 15px;")
          label Confirm Password
          input.studio-input(type="password" id="confirmPassword" placeholder="Minimum 6 characters" required minlength="6")
        
        button.btn-primary(type="submit" id="btnUpdatePassword" style="margin-top: 20px; width: 100%;") 
          i.fas.fa-lock(style="margin-right: 8px;")
          | Update Password

    .settings-section(style="margin-top: 40px; border: 1px solid #E74C3C; padding: 20px; border-radius: 8px; background: rgba(231, 76, 60, 0.05);")
      h3(style="color: #E74C3C; margin-bottom: 10px;") Danger Zone
      p(style="color: #E74C3C; margin-bottom: 20px;") Permanently delete your artist account and all associated data. This action CANNOT be undone.
      button(onclick="confirmAccountDeletion()" style="background: #E74C3C; color: white; padding: 12px 24px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold;") 
        i.fas.fa-trash-alt(style="margin-right: 8px;")
        | Delete Artist Account

