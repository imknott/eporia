//- ==========================================
//- IN-APP PAYMENT MODAL
//- views/partials/_payment-modal.pug
//-
//- Include at the bottom of userSignup.pug,
//- just before the closing </body> tag.
//- ==========================================

#paymentModal.payment-modal-overlay(style="display:none" aria-modal="true" role="dialog")
  .payment-modal-container
    
    //- ── Header ──────────────────────────────────────────────
    .pmod-header
      .pmod-header__left
        .pmod-logo EPORIA
        h2.pmod-title Complete Your Membership
      button.pmod-close(type="button" aria-label="Close" onclick="closePaymentModal()")
        i.fas.fa-times

    //- ── Two-column layout ──────────────────────────────────
    .pmod-body

      //- LEFT: Order summary ────────────────────────────────
      .pmod-summary

        .pmod-plan-badge#pmodPlanBadge
          i.fas.fa-music
          span.pmod-plan-name#pmodPlanName Supporter
          span.pmod-plan-interval#pmodPlanInterval · Monthly

        .pmod-price-row
          span.pmod-price-amount#pmodPriceAmount $12.99
          span.pmod-price-period /month

        .pmod-divider

        //- Allocation breakdown — updates dynamically
        .pmod-allocation
          h4.pmod-alloc-title How your money moves
          
          .pmod-alloc-mode#pmodAllocMode
            //- Filled by JS based on allocationMode
          
          .pmod-alloc-bars#pmodAllocBars
            //- Filled by JS

        .pmod-divider

        //- Renewal notice — filled by JS with billing interval and price
        p.pmod-renewal-notice#pmodRenewalNotice

        .pmod-secure-badge
          i.fas.fa-lock
          span Secured by Stripe · Global tax compliance
          i.fab.fa-stripe

      //- RIGHT: Stripe Elements ─────────────────────────────
      .pmod-elements-wrap

        //- Loading state while we create the subscription
        .pmod-loading#pmodLoading
          .pmod-spinner
          span Setting up secure payment...

        //- Error state
        .pmod-error#pmodError(style="display:none")
          i.fas.fa-exclamation-triangle
          span#pmodErrorText Something went wrong. Please try again.

        //- Stripe PaymentElement mounts here
        #stripe-payment-element(style="display:none")

        //- Payment method notice (local methods shown dynamically by Stripe)
        .pmod-local-hint#pmodLocalHint(style="display:none")
          i.fas.fa-globe
          span Payment options adjusted for your location

        //- Submit row
        .pmod-submit-row(style="display:none" id="pmodSubmitRow")
          .pmod-total-line
            span Total due today:
            strong#pmodTotalDue $12.99
          
          button.pmod-pay-btn#pmodPayBtn(type="button" onclick="confirmPayment()")
            span#pmodPayBtnText
              i.fas.fa-lock
              |  Pay & Activate Membership
            .pmod-pay-spinner(style="display:none")
              .pmod-spinner
          
          p.pmod-terms
            | By continuing you agree to our 
            a(href="/legal/terms" target="_blank") Terms of Service
            |  and authorize recurring billing. Cancel anytime.
