extends player_shell

block content
  //- Main Content Container
  .content-scroll(data-page="crate-view" data-crate-id=crate.id)

    //- ==============================
    //- CRATE HERO HEADER
    //- ==============================
    .crate-hero(style="background: linear-gradient(to bottom, rgba(0,0,0,0.6), var(--bg-main)), url('" + (crate.coverImage || (crate.tracks && crate.tracks.length > 0 ? (crate.tracks[0].artUrl || crate.tracks[0].img) : '')) + "') no-repeat center center; background-size: cover;")
      .crate-hero-inner

        //- Cover Art
        .crate-cover
          if crate.coverImage
            img(src=crate.coverImage alt=crate.title)
          else if crate.tracks && crate.tracks.length > 0
            img(src=crate.tracks[0].artUrl || crate.tracks[0].img || 'https://via.placeholder.com/300' alt=crate.title)
          else
            .crate-cover-placeholder
              i.fas.fa-box-open

        //- Crate Info
        .crate-info
          p.crate-badge CRATE

          h1.crate-title= crate.title

          if crate.description
            p.crate-description= crate.description

          //- Genre tags from metadata
          if crate.metadata && crate.metadata.genres && crate.metadata.genres.length > 0
            .crate-genre-tags
              each genre in crate.metadata.genres.slice(0, 6)
                span.crate-genre-tag= genre

          //- Creator & Stats
          .crate-meta
            if crate.creatorAvatar
              img.creator-avatar(src=crate.creatorAvatar alt=crate.creatorHandle)
            else
              .creator-avatar-placeholder
                i.fas.fa-user

            .creator-info
              .creator-byline
                span.creator-label Created by&nbsp;
                if crate.creatorHandle && crate.creatorHandle !== 'Unknown'
                  a.creator-handle(
                    href="javascript:void(0)"
                    onclick=`window.navigateTo('/player/u/${crate.creatorHandle.replace('@', '')}')`
                  )= crate.creatorHandle
                else
                  span.creator-handle Anonymous
              .crate-stats
                span
                  i.fas.fa-heart
                  | &nbsp;#{crate.likes || 0} Likes
                span.stat-dot •
                span
                  i.fas.fa-music
                  | &nbsp;#{crate.metadata ? crate.metadata.trackCount : (crate.tracks ? crate.tracks.length : 0)} Songs

          //- Action Buttons
          .crate-actions
            button.btn-play-all(onclick=`window.ui.playCrate('${crate.id}')`)
              i.fas.fa-play
              span Play All

            button.btn-shuffle(onclick="window.ui.playCrate(true)" title="Shuffle")
              i.fas.fa-random


    //- ==============================
    //- TRACK LIST
    //- ==============================
    .crate-tracks
      if crate.tracks && crate.tracks.length > 0
        //- Header Row
        .track-list-header
          .col-num #
          .col-title Title
          .col-artist Artist
          .col-duration
            i.far.fa-clock
          //- Extra column for cue button
          .col-cue
          .col-actions

        //- Track Rows
        .track-list-body
          each track, index in crate.tracks
            .track-row(
              onclick=`window.ui.playCrateTrack(${index})`
              data-song-id=track.id
              data-artist-id=(track.artistId || track.ownerId || track.uid)
            )
              .track-col.col-num
                span.track-number= index + 1
                i.fas.fa-play.track-play-icon

              .track-col.col-title
                if track.artUrl || track.img
                  img.track-thumb(src=track.artUrl || track.img alt=track.title)
                .track-title-text
                  .track-title= track.title
                  .track-artist-mobile= track.artist

              .track-col.col-artist
                span= track.artist

              .track-col.col-duration
                span= formatTime(track.duration)

              //- Cue button — hold to preview through cue output device
              .track-col.col-cue
                if track.audioUrl
                  button.track-cue-btn(
                    onmousedown=`event.stopPropagation(); window.workbench && window.workbench.cueTrack('${track.audioUrl}', '${track.title.replace(/'/g, "\\'")}')`
                    onmouseup="event.stopPropagation(); window.workbench && window.workbench.stopCue()"
                    ontouchstart=`event.stopPropagation(); window.workbench && window.workbench.cueTrack('${track.audioUrl}', '${track.title.replace(/'/g, "\\'")}')`
                    ontouchend="event.stopPropagation(); window.workbench && window.workbench.stopCue()"
                    title="Hold to cue (headphones)"
                  )
                    i.fas.fa-headphones

              .track-col.col-actions
                button.track-like-btn(
                  onclick=`event.stopPropagation(); window.toggleSongLike(this, '${track.id}', '${track.title.replace(/'/g, "\\'")}', '${track.artist.replace(/'/g, "\\'")}', '${track.artUrl || track.img}', '${track.audioUrl}', '${track.duration}', '${track.artistId || track.ownerId || track.uid}')`
                  data-song-id=track.id
                  title="Like"
                )
                  i.far.fa-heart

                button.track-more-btn(
                  onclick="event.stopPropagation(); window.ui.showToast('More options coming soon')"
                  title="More"
                )
                  i.fas.fa-ellipsis-h
      else
        .empty-crate
          i.fas.fa-box-open
          p This crate is empty
          p.text-muted The creator hasn't added any tracks yet

    //- Spacer for bottom player
    div(style="height: 120px")

    //- ── CRATE DATA for client hydration ──────────────────────────────────────
    //- CRITICAL: This MUST be its own isolated <script> tag, separate from all
    //- other inline JS. appRouter.js parses script blocks looking for
    //- window.__CRATE_DATA__ by finding the first '=' and JSON.parsing everything
    //- after it. If other JS functions follow the assignment in the same block,
    //- the parser grabs them too → "Unexpected non-whitespace character after JSON".
    script.
      try {
        window.__CRATE_DATA__ = !{crateDataJson};
      } catch(e) {
        console.warn('[crate_view] __CRATE_DATA__ parse error:', e);
        window.__CRATE_DATA__ = null;
      }

