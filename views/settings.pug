//- views/settings.pug
extends player_shell

block content
  .content-scroll(data-page="settings")
    h1.page-title Settings

    #saveStatus.settings-save-status
      i.fas.fa-check.settings-save-icon
      span Saved

    .settings-tabs
      button.tab-btn.active(onclick="switchSettingsTab('audio')") Audio
      button.tab-btn(onclick="switchSettingsTab('finance')") Wallet & Fair Trade
      button.tab-btn(onclick="switchSettingsTab('social')") Social & Privacy
      button.tab-btn(onclick="switchSettingsTab('account')") Account

    .settings-container

      //- --- TAB 1: AUDIO ---
      .tab-content#tab-audio
        h3.settings-group-title Equalizer
        .eq-container
          .eq-band
            span.eq-label High
            input.eq-slider(type="range" min="-10" max="10" value="0" name="eqHigh" oninput="updateEQ()")
          .eq-band
            span.eq-label Mid
            input.eq-slider(type="range" min="-10" max="10" value="0" name="eqMid" oninput="updateEQ()")
          .eq-band
            span.eq-label Low
            input.eq-slider(type="range" min="-10" max="10" value="0" name="eqLow" oninput="updateEQ()")

        h3.settings-group-title Playback

        .setting-row
          .setting-info
            .setting-label Streaming Quality
            .setting-desc Higher quality uses more data.
          .setting-control
            select.setting-select(name="audioQuality" onchange="updateSetting('audioQuality', this.value)")
              option(value="auto") Automatic
              option(value="high") High Fidelity (320kbps)
              option(value="saver") Data Saver

        .setting-row
          .setting-info
            .setting-label Volume Normalization
            .setting-desc Adjust tracks to the same volume.
          .setting-control
            label.toggle-switch
              input(type="checkbox" name="normalizeVolume" onchange="updateSetting('normalizeVolume', this.checked)")
              span.slider.round

        .setting-row
          .setting-info
            .setting-label Crossfade
            .setting-desc Overlap songs for smooth transitions.
          .setting-control
            .range-wrapper
              input#fadeRange(type="range" name="crossfade" min="0" max="12" value="3" onchange="updateSetting('crossfade', this.value)" oninput="document.getElementById('fadeVal').innerText = this.value + 's'")
              span#fadeVal.settings-fade-val 3s

      //- --- TAB 2: FINANCE ---
      .tab-content.tab-content--hidden#tab-finance
        .fair-trade-banner
          i.fas.fa-hand-holding-usd
          div
            strong Fair Trade Controls
            p You control your impact. Subscription: $#{subscription && subscription.price ? subscription.price : '12.99'}/mo

        h3.settings-group-title Allocation Strategy

        .setting-row
          .setting-info
            .setting-label Allocation Mode
            .setting-desc How do you want to distribute your monthly credits?
          .setting-control
            select.setting-select(name="allocationMode" onchange="updateSetting('allocationMode', this.value)")
              option(value="manual") Manual (Tip Artists Yourself)
              option(value="auto") Auto (Based on Engagement)

        .setting-row.setting-row--muted
          .setting-info
            .setting-label Unused Funds Policy
            .setting-desc Any unallocated funds at month end are automatically distributed to artists you followed, liked, or streamed.
          .setting-control
            i.fas.fa-check-circle.settings-check-icon

        .setting-row
          .setting-info
            .setting-label Public Support
            .setting-desc Show my username on artist "Top Supporters" lists.
          .setting-control
            label.toggle-switch
              input(type="checkbox" name="publicReceipts" onchange="updateSetting('publicReceipts', this.checked)")
              span.slider.round

      //- --- TAB 3: SOCIAL ---
      .tab-content.tab-content--hidden#tab-social
        h3.settings-group-title Privacy

        .setting-row
          .setting-info
            .setting-label Ghost Mode
            .setting-desc Listen without updating history or followers.
          .setting-control
            label.toggle-switch
              input(type="checkbox" name="ghostMode" onchange="updateSetting('ghostMode', this.checked)")
              span.slider.round

        .setting-row
          .setting-info
            .setting-label Local Scene Visibility
            .setting-desc Show my public playlists in the Local Feed.
          .setting-control
            label.toggle-switch
              input(type="checkbox" name="localVisibility" onchange="updateSetting('localVisibility', this.checked)")
              span.slider.round

        .setting-row
          .setting-info
            .setting-label Taste Match
            .setting-desc Allow others to see our compatibility score.
          .setting-control
            label.toggle-switch
              input(type="checkbox" name="tasteMatch" onchange="updateSetting('tasteMatch', this.checked)")
              span.slider.round

      //- --- TAB 4: ACCOUNT ---
      .tab-content.tab-content--hidden#tab-account
        h3.settings-group-title Appearance
        .setting-row
          .setting-info
            .setting-label Interface Theme
            .setting-desc Choose your visual vibe.
          .setting-control
            select.setting-select(name="theme" onchange="updateSetting('theme', this.value)")
              option(value="electronic") Electronic (Neon)
              option(value="hip-hop") Hip Hop (Gold)
              option(value="rock") Rock (Grunge)
              option(value="pop") Pop (Vibrant)
              option(value="jazz") Jazz (Classic)
              option(value="classical") Classical (Elegant)

        h3.settings-group-title Membership
        .setting-row
          .setting-info
            .setting-label Current Plan
            .setting-desc#settingsPlanDesc #{subscription && subscription.plan ? subscription.plan : 'Individual'} Plan
          .setting-control
            button#manageBillingBtn.btn-text(type="button")
              i.fas.fa-external-link-alt.btn-text__icon
              | Manage Billing

        h3.settings-group-title Security
        .setting-row
          .setting-info
            .setting-label Email
            .setting-desc#settingsEmail #{user ? user.email : 'Loading...'}
          .setting-control

        .setting-row
          .setting-info
            .setting-label Password
            .setting-desc Update your account password.
          .setting-control
            button#changePasswordBtn.btn-text(type="button") Change Password

        h3.settings-group-title.settings-group-title--danger Danger Zone
        .setting-row.setting-row--danger
          .setting-info
            .setting-label.setting-label--danger Delete Account
            .setting-desc All your data — listens, tips, playlists, and profile — will be permanently deleted and cannot be recovered. Your subscription will be cancelled at the end of the current billing period.
          .setting-control
            button#deleteAccountBtn.btn-text.btn-text--danger(type="button") Delete Account

      button#saveSettingsBtn.btn-alloc.primary Save Changes

    .settings-bottom-spacer

  //- ── CHANGE PASSWORD MODAL ──────────────────────────────────────
  #passwordModal.settings-modal
    .settings-modal__card
      .settings-modal__header
        h2.settings-modal__title
          i.fas.fa-lock.settings-modal__title-icon
          | Change Password
        button.settings-modal__close(onclick="closePasswordModal()")
          i.fas.fa-times
      .settings-form-group
        label.settings-form-label Current Password
        input#currentPassword.settings-form-input(type="password" placeholder="Enter current password")
      .settings-form-group
        label.settings-form-label New Password
        input#newPassword.settings-form-input(type="password" placeholder="At least 8 characters")
      .settings-form-group.settings-form-group--last
        label.settings-form-label Confirm New Password
        input#confirmPassword.settings-form-input(type="password" placeholder="Repeat new password")
      p#passwordError.settings-form-error
      .settings-modal__footer
        button.btn-modal-cancel(onclick="closePasswordModal()") Cancel
        button#submitPasswordBtn.btn-modal-submit(onclick="submitPasswordChange()") Update Password

  //- ── DELETE ACCOUNT MODAL ───────────────────────────────────────
  #deleteAccountModal.settings-modal.settings-modal--danger
    .settings-modal__card.settings-modal__card--danger
      .settings-modal__header
        h2.settings-modal__title.settings-modal__title--danger
          i.fas.fa-exclamation-triangle.settings-modal__title-icon
          | Delete Account
        button.settings-modal__close(onclick="closeDeleteModal()")
          i.fas.fa-times
      .delete-warning
        p.delete-warning__title
          i.fas.fa-skull-crossbones.delete-warning__icon
          | This action is permanent and irreversible.
        ul.delete-warning__list
          li Your profile, playlists, and listening history will be deleted
          li All tips and wallet balance will be forfeited
          li Your subscription will cancel at the end of the billing period
          li This data cannot be recovered under any circumstances
      .settings-form-group.settings-form-group--last
        label.settings-form-label
          | To confirm, type 
          strong.delete-confirm-keyword DELETE
          |  in the box below:
        input#deleteConfirmInput.settings-form-input.delete-confirm-input(type="text" placeholder="Type DELETE to confirm" autocomplete="off" oninput="onDeleteInputChange(this)")
      p#deleteError.settings-form-error
      .settings-modal__footer
        button.btn-modal-cancel(onclick="closeDeleteModal()") Cancel
        button#confirmDeleteBtn.btn-modal-submit.btn-modal-submit--danger(onclick="submitDeleteAccount()" disabled) Delete My Account
