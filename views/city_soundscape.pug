doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title City Soundscape Map

    //- MapLibre GL JS
    link(href='https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.css', rel='stylesheet')
    script(src='https://unpkg.com/maplibre-gl@3.6.2/dist/maplibre-gl.js')

    //- All styles live in city-soundscape-map.css — nothing inline here.

  body
    //- Modal Structure (injected into your app shell)
    #cityMapModal(style="display: none;")
      .map-container
        //- Map — ID must match container: 'soundscapeMap' in citySoundscapeMap.js initMap()
        #soundscapeMap

        //- Close Button
        .close-btn(onclick="window.cityMap && window.cityMap.close()")
          i.fas.fa-times

        //- Info Panel
        .info-panel
          h2 Sound-Scape
          p Explore cities by their musical energy

        //- City Card (shows on hover/click)
        #cityCard.city-card
          .city-card-header
            #cityOrb.city-orb
            .city-card-info
              h3#cityName
              p#cityLocation

          .taste-match
            #tasteScore.taste-match-score --
            .taste-match-text
              strong#tasteMatchLabel Taste Match
              br
              span#tasteMatchDesc Based on your listening history

          .city-stats
            .stat
              span#artistCount.stat-value 0
              span.stat-label Artists
            .stat
              span#trackCount.stat-value 0
              span.stat-label Tracks
            .stat
              span#recentCount.stat-value 0
              span.stat-label Crates

          #genreTags.genre-tags
            //- Populated dynamically by showCityCard()

          #pioneerBadge.pioneer-badge(style="display: none;")
            i.fas.fa-medal
            |  Founding Artists Here

          .city-actions
            button.btn-explore(onclick="window.cityMap && window.cityMap.exploreCity()")
              i.fas.fa-compass
              |  Explore Scene
            button#previewBtn.btn-preview(onclick="window.cityMap && window.cityMap.previewSound()")
              i.fas.fa-play

        //- Legend — colors via CSS classes, matching GENRE_COLORS in citySoundscapeMap.js
        .map-legend
          .legend-title Genre Colors
          .legend-item
            .legend-color.genre-pop
            span Pop
          .legend-item
            .legend-color.genre-hiphop
            span Hip-Hop
          .legend-item
            .legend-color.genre-electronic
            span Electronic
          .legend-item
            .legend-color.genre-rnb
            span R&B
          .legend-item
            .legend-color.genre-rock
            span Rock

    script.
      // This pug is the static shell — citySoundscapeMap.js detects that
      // #cityMapModal already exists and skips createModal(), using this
      // structure directly. All element IDs must match what showCityCard()
      // and initMap() expect — see citySoundscapeMap.js for the canonical list.
      console.log('🗺️ City Map Modal shell ready — waiting for CitySoundscapeMap.init()');
