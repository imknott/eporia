//- views/artist_profile.pug
extends player_shell

block content
  .content-scroll(data-page="artist-profile" data-artist-id=artist.id data-artist-avatar=artist.profileImage data-artist-name=artist.name)
    //- HERO
    .artist-hero-compact(style=`background-image: linear-gradient(to right, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 100%), url('${artist.bannerImage || artist.profileImage || "https://images.unsplash.com/photo-1493225255756-d9584f8606e9?w=1200"}')`)
      .hero-content-row
        img.hero-avatar-small(src=artist.profileImage || "https://via.placeholder.com/150")
        .hero-text-row
          h1 #{artist.name}
          .meta-row
            if artist.musicProfile && artist.musicProfile.primaryGenre
              span.genre #{artist.musicProfile.primaryGenre}
            else
              span.genre Artist
            span.dot •
            span.loc #{artist.location || "Global"}

          .action-row
            button.btn-follow-sm#followBtn(
                onclick="toggleFollow(this)"
                data-artist-id=artist.id
                data-artist-name=artist.name
                data-artist-img=artist.profileImage
            ) Follow

            button.btn-tip-sm(onclick=`window.ui.openTipModal('${artist.id}', '${artist.name.replace(/'/g, "\\'")}')`)
              i.fas.fa-dollar-sign
              |  Tip Artist

    //- TABS
    .profile-tabs
      button.tab-btn.active(onclick="switchArtistTab('music')") Music
      button.tab-btn(onclick="switchArtistTab('albums')") Albums
      button.tab-btn(onclick="switchArtistTab('merch')") Store
      button.tab-btn(onclick="switchArtistTab('community')") Community

    //- ══════════════════════════════════════
    //- TAB: MUSIC
    //- ══════════════════════════════════════
    .tab-content#tab-music
      .bio-summary
        p #{artist.bio || "No bio available yet."}
        if artist.musicProfile && artist.musicProfile.subgenres
          .tags-row
            each tag in artist.musicProfile.subgenres
              span.tag ##{tag}

      h3.sub-header Featured Tracks
      .track-list-compact
        if tracks && tracks.length > 0
          each track, index in tracks
            .track-row
              span.track-num #{index + 1}
              img.track-img(src=track.artUrl)
              .track-info-row
                span.t-title #{track.title}
              .row-controls(style="display:flex; gap:10px; align-items:center; margin-right:15px")
                button.row-btn(
                  onclick=`playSong('${track.id}', '${track.title.replace(/'/g, "\\'")}', '${artist.name.replace(/'/g, "\\'")}', '${track.artUrl}', '${track.audioUrl}', '${track.duration}', '${artist.id}')`
                  title="Play"
                )
                  i.fas.fa-play
                button.row-btn(
                  onclick=`addToQueue('${track.id}', '${track.title.replace(/'/g, "\\'")}', '${artist.name.replace(/'/g, "\\'")}', '${track.artUrl}', '${track.audioUrl}', '${track.duration}', '${artist.id}')`
                  title="Add to Queue"
                )
                  i.fas.fa-list
                button.row-btn(
                  onclick=`toggleSongLike(this, '${track.id}', '${track.title.replace(/'/g, "\\'")}', '${artist.name.replace(/'/g, "\\'")}', '${track.artUrl}', '${track.audioUrl}', '${track.duration}')`
                  title="Like"
                  data-song-id=track.id
                )
                  i.far.fa-heart
              span.t-time #{formatTime(track.duration)}
        else
          .empty-state(style="text-align:center; padding: 40px; color: #888")
            p No releases yet.

    //- ══════════════════════════════════════
    //- TAB: ALBUMS
    //- ══════════════════════════════════════
    .tab-content#tab-albums(style="display: none;")
      if albums && albums.length > 0
        .albums-grid
          each album in albums
            .album-card
              .album-art-wrap
                img.album-art(src=album.artUrl alt=album.title)
                .album-play-overlay
                  i.fas.fa-play
              .album-info
                span.album-title #{album.title}
                span.album-meta #{album.trackCount} track#{album.trackCount !== 1 ? 's' : ''}
      else
        .empty-state(style="text-align:center; padding: 40px; color: #888")
          i.fas.fa-record-vinyl(style="font-size:2.5rem; margin-bottom:12px; display:block;")
          p No albums yet.

    //- ══════════════════════════════════════
    //- TAB: MERCH
    //- ══════════════════════════════════════
    .tab-content#tab-merch(style="display: none;")
      h3.sub-header Official Merch
      .empty-state(style="text-align:center; padding: 40px; color: #888")
        p Merch store coming soon.

    //- ══════════════════════════════════════
    //- TAB: COMMUNITY — COLLAGE WALL
    //- ══════════════════════════════════════
    .tab-content#tab-community(style="display: none;")
      .community-wall

        //- ── Post Detail Modal ──────────────────────────────────────
        #postModal.post-modal-overlay(style="display:none;")
          .post-modal-card
            button.post-modal-close(onclick="window.artistPosts.closeModal()")
              i.fas.fa-times

            .post-modal-body
              //- Left: Image
              .post-modal-image-wrap
                img#postModalImage(src="" alt="Post image")

              //- Right: Comments panel
              .post-modal-panel
                .post-modal-header
                  img#postModalAvatar.post-modal-avatar(src="" alt="")
                  .post-modal-artist-info
                    strong#postModalArtistName
                    span#postModalTime.post-modal-time

                p#postModalCaption.post-modal-caption

                .post-modal-stats
                  button.post-like-btn#postModalLikeBtn(onclick="window.artistPosts.togglePostLike()")
                    i#postModalLikeIcon.far.fa-heart
                    span#postModalLikeCount  0
                  span.post-modal-comment-count
                    i.far.fa-comment
                    span#postModalCommentCount  0

                .post-modal-divider

                //- Comments list
                .post-modal-comments#postModalComments
                  //- JS populates

                .post-modal-loading#postModalCommentsLoading(style="display:none;")
                  i.fas.fa-spinner.fa-spin

                //- Comment input (followers only)
                #postModalCommentForm.post-modal-input-area(style="display:none;")
                  img#postModalUserAvatar.post-comment-avatar(src="https://via.placeholder.com/32" alt="")
                  .post-comment-input-wrap
                    textarea#postModalCommentInput.post-comment-input(placeholder="Add a comment..." rows="1")
                    button#postModalSubmitBtn.post-comment-submit(type="button" disabled)
                      i.fas.fa-paper-plane

                //- Follow gate
                #postModalFollowGate.post-follow-gate(style="display:none;")
                  i.fas.fa-lock
                  span Follow to join the conversation
                  button.btn-action-sm.primary(onclick="document.getElementById('followBtn').click()")  Follow

        //- ── Wall Header ─────────────────────────────────────────────
        .wall-header
          h3.wall-title
            i.fas.fa-images
            |  From the Artist
          button.wall-load-more-btn#wallLoadMoreBtn(style="display:none;" onclick="window.artistPosts.loadMore()")
            | Load more

        //- ── Posts Grid ──────────────────────────────────────────────
        .wall-grid#wallGrid
          //- JS populates post cards here

        .wall-empty#wallEmpty(style="display:none;")
          i.fas.fa-camera-retro
          p No posts yet. Follow along and check back soon!

        .wall-loading#wallLoading
          each n in [1,2,3,4,5,6]
            .wall-skeleton

    div(style="height: 120px")
