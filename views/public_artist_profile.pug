//- views/public_artist_profile.pug
//- Public artist profile — cyberpunk aesthetic, store-integrated cart.
//- Data from public_profile.js:
//-   artist   { id, slug, name, bio, location, profileImage, bannerImage,
//-              musicProfile.primaryGenre, musicProfile.subgenres,
//-              stats.followers }
//-   tracks   [{ id, title, plays, durationFormatted, artUrl, digitalPrice }]
//-   albums   [{ id, title, artUrl, trackCount }]
//-   playerUrl      "/player/artist/:slug"
//-   canonicalUrl   "https://eporia.com/artist/:slug"

extends public_shell

block meta
  meta(property="og:description" content=artist.bio || `${artist.name} on Eporia`)
  if artist.bannerImage || artist.profileImage
    meta(property="og:image" content=artist.bannerImage || artist.profileImage)


block content
  //- Dataset for public_store.js to read
  div(data-artist-id=artist.id style="display:none")

  //- ── HERO ────────────────────────────────────────────────────────
  .artist-hero-pub(style=`background-image: url('${artist.bannerImage || artist.profileImage || "https://images.unsplash.com/photo-1493225255756-d9584f8606e9?w=1200"}')`)
    .artist-hero-content
      img.artist-hero-avatar(
        src=artist.profileImage || "https://via.placeholder.com/120"
        alt=artist.name
      )
      .artist-hero-text
        p.artist-hero-eyebrow // ARTIST PROFILE
        h1.artist-hero-name #{artist.name}

        .artist-meta-row
          - var genre = (artist.musicProfile && artist.musicProfile.primaryGenre) || artist.primaryGenre
          if genre
            span.genre-badge-pub #{genre}
            span.dot •
          span
            i.fas.fa-map-marker-alt(style="opacity:0.5;margin-right:5px")
            | #{artist.location || 'Global'}
          if artist.stats && artist.stats.followers
            span.dot •
            span.stat-followers
              strong #{(artist.stats.followers || 0).toLocaleString()}
              |  followers

        .artist-hero-actions
          a.btn-hero-listen(href=playerUrl)
            i.fas.fa-headphones
            | Listen on Eporia
          button.btn-nav-ghost(
            onclick=`pubShareNative('${artist.name} on Eporia', 'Check out ${artist.name} on Eporia — the artist-first music platform.', '${canonicalUrl}')`
          )
            i.fas.fa-share-alt
            |  Share

  //- ── SOCIAL SHARE ROW ────────────────────────────────────────────
  .pub-share-row(style="margin-top:20px")
    span.pub-share-label SHARE:
    button.btn-share-platform.twitter(
      onclick=`pubShareTwitter('Check out ${artist.name} on Eporia — real music, real artists.', '${canonicalUrl}')`
    )
      i.fab.fa-x-twitter
      |  X / Twitter
    button.btn-share-platform.facebook(
      onclick=`pubShareFacebook('${canonicalUrl}')`
    )
      i.fab.fa-facebook-f
      |  Facebook
    button.btn-share-platform.whatsapp(
      onclick=`pubShareWhatsApp('Check out ${artist.name} on Eporia:', '${canonicalUrl}')`
    )
      i.fab.fa-whatsapp
      |  WhatsApp
    button.btn-share-platform.copy#shareCopyBtn(
      onclick=`pubShare('${canonicalUrl}', this)`
    )
      i.fas.fa-link
      |  Copy Link

  //- ── TABS ────────────────────────────────────────────────────────
  .pub-tabs
    button.pub-tab-btn.active(data-tab="music"    onclick="pubSwitchTab('music')")   Music
    button.pub-tab-btn(        data-tab="albums"   onclick="pubSwitchTab('albums')")  Albums
    button.pub-tab-btn(        data-tab="merch"    onclick="pubSwitchTab('merch')")   Merch

  //- ── TAB: MUSIC ──────────────────────────────────────────────────
  .pub-tab-panel#tab-music

    //- Bio
    if artist.bio
      p(style="font-family:'Rajdhani',sans-serif;font-size:1rem;line-height:1.75;color:var(--text-secondary);margin-bottom:20px;max-width:700px;") #{artist.bio}

    //- Genre tags
    - var tags = (artist.musicProfile && artist.musicProfile.subgenres) || artist.subgenres || []
    if tags.length
      .pub-bio-tags(style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px")
        each tag in tags
          span.pub-tag ##{tag}

    //- ── DIGITAL TRACK PURCHASE (Bandcamp-style) ──────────────────
    h3.pub-section-header(style="margin-bottom:16px")
      i.fas.fa-music(style="margin-right:8px;opacity:0.5")
      | Tracks
    p(style="font-family:'Rajdhani',sans-serif;font-size:0.85rem;color:var(--text-muted);margin-bottom:16px;")
      | Sign in to stream free on Eporia, or purchase a digital download to own.

    if tracks && tracks.length > 0
      .pub-track-list
        each track, index in tracks
          .pub-track-row
            span.pub-track-num #{index + 1}
            img.pub-track-img(
              src=track.artUrl || "https://via.placeholder.com/44"
              alt=track.title
            )
            .pub-track-info
              p.pub-track-title #{track.title}
              p.pub-track-plays #{(track.plays || 0).toLocaleString()} plays
            //- Actions: buy + sign-in gate
            .pub-track-actions
              if track.digitalPrice && track.digitalPrice > 0
                button.btn-buy-track(
                  onclick=`addDigitalToCart('${track.id}','${track.title.replace(/'/g,"\\'")}','${artist.id}','${artist.name.replace(/'/g,"\\'")}','${track.artUrl}',${track.digitalPrice},this)`
                )
                  i.fas.fa-download
                  | Buy $#{Number(track.digitalPrice).toFixed(2)}
              else
                span.pub-track-free-badge FREE
              a.pub-lock-gate(href=`/members/signin?redirect=${encodeURIComponent(playerUrl)}`)
                i.fas.fa-lock
                | Sign in to play
            span.pub-track-duration #{track.durationFormatted || '—'}

      p(style="text-align:center;margin-top:18px;font-family:'Rajdhani',sans-serif;font-size:0.85rem;color:var(--text-muted)")
        | Stream every track in full, build crates, follow artists.&nbsp;
        a(href="/members/signup" style="color:var(--primary);font-weight:700") Create a free account →

    else
      .pub-empty
        i.fas.fa-music
        p No releases yet.

  //- ── TAB: ALBUMS ─────────────────────────────────────────────────
  .pub-tab-panel#tab-albums(style="display:none")
    if albums && albums.length > 0
      .pub-albums-grid
        each album in albums
          .pub-album-card
            .pub-album-art-wrap
              img.pub-album-art(src=album.artUrl alt=album.title)
              .pub-album-overlay
            .pub-album-info
              span.pub-album-title #{album.title}
              span.pub-album-meta #{album.trackCount} track#{album.trackCount !== 1 ? 's' : ''}
    else
      .pub-empty
        i.fas.fa-record-vinyl
        p No albums yet.

  //- ── TAB: MERCH ──────────────────────────────────────────────────
  .pub-tab-panel#tab-merch(style="display:none")

    //- Artist merch section — populated by public_store.js on load
    section#artistMerchSection
      h3.pub-section-header(style="margin-bottom:16px")
        i.fas.fa-tshirt(style="margin-right:8px;opacity:0.5")
        | Official Merch
      p(style="font-family:'Rajdhani',sans-serif;font-size:0.85rem;color:var(--text-muted);margin-bottom:20px")
        | 100% of listed price goes directly to #{artist.name}.
        | A small 10% supporter fee is added at checkout and keeps Eporia running.
      .pub-merch-grid#artistMerchGrid

    //- Loading state
    #artistMerchLoading.merch-loading
      i.fas.fa-spinner
      span Loading merch...

    //- Empty state (shown by JS if no items)
    .pub-empty#artistMerchEmpty(style="display:none")
      i.fas.fa-tshirt
      p No merch listed yet.

block cta_strip
  .pub-cta-strip
    .pub-cta-left
      .pub-cta-icon
        i.fas.fa-headphones
      .pub-cta-text
        strong #{artist.name} is on Eporia
        span Stream full tracks, follow, buy merch — all in one place
    .pub-cta-actions
      a.btn-cta-open(href="/members/signup")
        i.fas.fa-user-plus
        | Join Free
      a.btn-cta-open(href=playerUrl style="box-shadow:none;border-color:var(--text-muted);color:var(--text-secondary)")
        i.fas.fa-play
        | Open Player
