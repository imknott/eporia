doctype html
html(lang="en")
  head
    title Artist Applications | Eporia Admin
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    link(rel="stylesheet" href="/stylesheets/admin.css")
    style.
      .filter-pills { display:flex; gap:8px; flex-wrap:wrap; }
      .filter-pill {
        padding: 6px 14px;
        font-family: 'Share Tech Mono', monospace;
        font-size: .62rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        border: 1px solid var(--bdr2);
        color: var(--txt3);
        background: transparent;
        cursor: pointer;
        transition: all .2s;
      }
      .filter-pill.active, .filter-pill:hover {
        border-color: var(--cy);
        color: var(--cy);
        background: var(--cy-dim);
      }

  body
    #loadingScreen.loading-screen
      .loading-logo EPORIA
      .loading-bar-wrap
        .loading-bar
      p.loading-text LOADING REVIEW QUEUE...

    #mainContent(style="display:none")

      nav.admin-nav
        a.nav-logo(href="/admin/dashboard") EPORIA
        .nav-links
          a.nav-link(href="/admin/dashboard")
            i.fas.fa-tachometer-alt
            | Dashboard
          a.nav-link.active(href="/admin/artists/review")
            i.fas.fa-user-check
            | Artist Reviews
          a.nav-link(href="/admin/messages")
            i.fas.fa-comments
            | Messages
            span.nav-badge#msgNavBadge(style="display:none") 0
        .nav-right
          .nav-user-info
            .nav-user-name#navUserName LOADING...
            .nav-user-role ADMINISTRATOR
          button.btn-logout
            i.fas.fa-sign-out-alt
            | EXIT

      .admin-body
        .page-header-row
          div
            h1.page-title ARTIST REVIEW PANEL
            p.page-sub SYS://ADMIN.ARTISTS — INCOMING APPLICATIONS
          .filter-pills
            button.filter-pill.active(data-priority="all") ALL
            button.filter-pill(data-priority="high")
              i.fas.fa-star(style="margin-right:4px")
              | HIGH
            button.filter-pill(data-priority="medium")
              i.fas.fa-exclamation(style="margin-right:4px")
              | MEDIUM
            button.filter-pill(data-priority="normal") NORMAL

        .stats-grid(style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr))")
          .stat-card
            .stat-label
              i.fas.fa-inbox
              | In Queue
            .stat-number#statPending --
          .stat-card.priority
            .stat-label
              i.fas.fa-star
              | High Priority
            .stat-number#statPriority --
          .stat-card
            .stat-label
              i.fas.fa-exclamation-triangle
              | Licensing Review
            .stat-number#statMedium --

        .review-list#reviewList
          .empty-state
            i.fas.fa-spinner.fa-spin
            h3 Loading Applications
            p Fetching artist queue...

    //- Approval Wizard Modal
    #approveModal.modal-overlay
      .modal-box
        .modal-header
          span.modal-title
            i.fas.fa-check-circle(style="margin-right:8px")
            | ARTIST APPROVAL WIZARD
          span.modal-step-indicator#wizardStepText STEP 01 // CONFIRM
          button.modal-close(type="button" onclick="closeWizard()")
            i.fas.fa-times

        .modal-body

          //- Step 1: Confirm
          #step1.wizard-step
            p.field-label(style="margin-bottom:12px") APPROVING THE FOLLOWING ARTIST:
            .artist-preview
              .review-name#targetArtistName Artist Name
              .review-handle#targetArtistHandle @handle
              .meta-chip(style="margin-top:8px")
                i.fas.fa-envelope(style="margin-right:6px")
                span#targetArtistEmail email@domain.com
            p(style="font-family:'Share Tech Mono',monospace;font-size:.72rem;color:var(--txt3);line-height:1.7;margin-top:14px")
              | This action will create a Firebase Auth account, set status to approved,
              br
              | and trigger the artist welcome email sequence.

          //- Step 2: Credentials
          #step2.wizard-step(style="display:none")
            label.field-label(for="tempPassword") TEMPORARY PASSWORD *
            input#tempPassword.field-input(
              type="text"
              placeholder="e.g. Eporia2026!"
            )
            p.field-hint Min. 6 characters. You will email this to the artist.

            label.field-label(for="adminNotes") INTERNAL REVIEW NOTES
            textarea#adminNotes.field-textarea(
              rows="3"
              placeholder="e.g. Verified via official Spotify link. ISRC confirmed."
            )

          //- Step 3: Success
          #step3.wizard-step(style="display:none")
            .success-icon
              i.fas.fa-check-circle
            h3(style="font-family:'Orbitron',sans-serif;font-size:.85rem;letter-spacing:3px;text-align:center;color:var(--cy);margin-bottom:8px") ACCOUNT CREATED
            p(style="font-family:'Share Tech Mono',monospace;font-size:.72rem;color:var(--txt3);text-align:center;margin-bottom:18px") Copy and send these credentials to the artist.
            .credentials-box
              .cred-label EMAIL
              .cred-val#finalEmail —
              .cred-label PASSWORD
              .cred-val#finalPass —
            button#btnCopy.btn-cy(onclick="copyToClipboard()" style="width:100%;justify-content:center")
              i.fas.fa-copy
              | COPY CREDENTIALS

        #wizardFooter.modal-footer
          button.btn-ghost(type="button" onclick="closeWizard()") CANCEL
          div(style="display:flex;gap:8px")
            button#btnBack.btn-ghost(type="button" onclick="moveWizard(-1)" style="display:none")
              i.fas.fa-arrow-left
              | BACK
            button#btnNext.btn-cy(type="button" onclick="moveWizard(1)" style="display:none") NEXT
            button#btnFinal.btn-cy(type="button" onclick="executeApproval()" style="display:none")
              i.fas.fa-check
              | COMPLETE APPROVAL

    script(src="/javascripts/admin-common.js")
    script(src="/javascripts/admin-reviews.js")