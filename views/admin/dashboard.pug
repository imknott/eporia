doctype html
html(lang="en")
  head
    title Admin Dashboard | Eporia
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    link(rel="stylesheet" href="/stylesheets/admin.css")

  body
    //- Loading screen
    #loadingScreen.loading-screen
      .loading-logo EPORIA
      .loading-bar-wrap
        .loading-bar
      p.loading-text VERIFYING ACCESS...

    //- Main content
    #mainContent(style="display:none")

      nav.admin-nav
        a.nav-logo(href="/admin/dashboard") EPORIA
        .nav-links
          a.nav-link.active(href="/admin/dashboard")
            i.fas.fa-tachometer-alt
            | Dashboard
          a.nav-link(href="/admin/artists/review")
            i.fas.fa-user-check
            | Artist Reviews
          a.nav-link(href="/admin/messages")
            i.fas.fa-comments
            | Messages
            span.nav-badge#msgNavBadge(style="display:none") 0
        .nav-right
          .nav-user-info
            .nav-user-name#navUserName LOADING...
            .nav-user-role#navUserRole ADMINISTRATOR
          button.btn-logout
            i.fas.fa-sign-out-alt
            | EXIT

      .admin-body
        .page-header-row
          div
            h1.page-title COMMAND CENTER
            p.page-sub SYS://ADMIN.DASHBOARD — REAL-TIME PLATFORM OVERVIEW
          span(style="font-family:'Share Tech Mono',monospace;font-size:.65rem;color:var(--txt3)") #[span#liveTime]

        //- Stats row 1 — artist pipeline
        h2.section-heading ARTIST PIPELINE
        .stats-grid
          .stat-card
            .stat-label
              i.fas.fa-clock
              | Pending Reviews
            .stat-number#statPending --
            .stat-sub Awaiting human review
          .stat-card.priority
            .stat-label
              i.fas.fa-star
              | High Priority
            .stat-number#statPriority --
            .stat-sub Artists with ISRC
          .stat-card
            .stat-label
              i.fas.fa-exclamation-triangle
              | Licensing Follow-up
            .stat-number#statLicensing --
            .stat-sub PRO/MLC/Publisher checks
          .stat-card.approved
            .stat-label
              i.fas.fa-check-circle
              | Approved Today
            .stat-number#statApproved --
            .stat-sub Artists onboarded today
          .stat-card
            .stat-label
              i.fas.fa-users
              | Total Users
            .stat-number#statUsers --
            .stat-sub All-time platform users
          .stat-card
            .stat-label
              i.fas.fa-stopwatch
              | Avg Review Time
            .stat-number#statAvgTime --
            .stat-sub Last 10 approvals

        //- Stats row 2 — messages
        h2.section-heading GUEST INBOX
        .stats-grid(style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr));margin-bottom:40px")
          .stat-card.messages
            .stat-label
              i.fas.fa-comment-dots
              | Unread Messages
            .stat-number#statMessages --
            .stat-sub Guest chat conversations

        //- Quick actions
        h2.section-heading QUICK ACTIONS
        .actions-grid
          a.action-card(href="/admin/artists/review")
            .action-icon
              i.fas.fa-user-check
            .action-title Artist Reviews
            p.action-sub Review and approve pending artist signup applications
            .action-cta OPEN REVIEW PANEL

          a.action-card(href="/admin/messages")
            .action-icon(style="border-color:var(--mg);color:var(--mg)")
              i.fas.fa-comments
            .action-title Guest Messages
            p.action-sub Respond to visitors who asked questions in the landing chatbox
            .action-cta(style="color:var(--mg)") OPEN INBOX

          .action-card.disabled
            .action-icon
              i.fas.fa-users
            .action-title User Management
            p.action-sub View and manage all platform users
            .action-cta COMING SOON

          .action-card.disabled
            .action-icon
              i.fas.fa-chart-line
            .action-title Analytics
            p.action-sub Platform-wide metrics and reports
            .action-cta COMING SOON

    script(src="/javascripts/admin-common.js")
    script(src="/javascripts/admin-dashboard.js")
    script.
      // Live clock
      function tick() {
        const el = document.getElementById('liveTime');
        if (el) el.textContent = new Date().toUTCString().replace('GMT','UTC');
      }
      tick();
      setInterval(tick, 1000);
